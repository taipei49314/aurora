{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/import-package.schema.json",
  "title": "AURORA import package",
  "description": "Package accepted by import_package(). See docs/import-schema.md.",
  "type": "object",
  "required": ["entities", "sources", "observations"],
  "additionalProperties": true,
  "properties": {
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/observation" }
    }
  },
  "$defs": {
    "entityType": {
      "type": "string",
      "enum": [
        "COMPANY", "RESEARCH_INSTITUTE", "UNIVERSITY", "GOVERNMENT", "STANDARD_BODY",
        "PRODUCT", "TECHNOLOGY", "MATERIAL", "COMPONENT", "PROCESS", "FACILITY",
        "APPLICATION", "MARKET"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "COMPANY_FILING", "PATENT", "PAPER", "JOB_POSTING",
        "NEWS", "GOVERNMENT_PROGRAM", "STANDARD", "RESEARCH_NOTE"
      ]
    },
    "observationType": {
      "type": "string",
      "enum": [
        "PATENT_ACTIVITY", "HIRING_ACTIVITY", "CAPEX_ACTIVITY", "CAPACITY_EXPANSION",
        "PRODUCT_LAUNCH", "TECHNICAL_DEPENDENCY", "SUPPLIER_RELATIONSHIP",
        "CUSTOMER_RELATIONSHIP", "STRATEGIC_INVESTMENT", "STANDARD_ACTIVITY",
        "RESEARCH_ACTIVITY", "PRICE_PRESSURE", "LEAD_TIME_PRESSURE",
        "REGULATORY_SUPPORT", "ADOPTION_SIGNAL", "DEMAND_SIGNAL",
        "CANCELLATION_SIGNAL", "SHUTDOWN_SIGNAL"
      ]
    },
    "reliabilityTier": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "entity": {
      "type": "object",
      "required": ["entity_type", "canonical_name"],
      "additionalProperties": true,
      "properties": {
        "entity_type": { "$ref": "#/$defs/entityType" },
        "canonical_name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" },
        "country": { "type": "string" },
        "external_ids": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["system", "id"],
            "properties": {
              "system": { "type": "string" },
              "id": { "type": "string" }
            }
          }
        },
        "metadata": { "type": "object" }
      }
    },
    "source": {
      "type": "object",
      "required": ["source_type", "publisher", "title"],
      "additionalProperties": true,
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "source_type": { "$ref": "#/$defs/sourceType" },
        "publisher": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "published_at": {
          "type": ["string", "null"],
          "description": "Publication/grant ISO date; first 10 chars used as date"
        },
        "event_date": {
          "type": ["string", "null"],
          "description": "Activity/application/filing date (dual-date with published_at); first 10 chars used"
        },
        "excerpt": { "type": "string" },
        "independence_group": { "type": "string" },
        "reliability_tier": { "$ref": "#/$defs/reliabilityTier" },
        "url_or_local_path": { "type": "string" },
        "language": { "type": "string" },
        "family_id": {
          "type": "string",
          "description": "Patent/document family id; when set, independence_group defaults to family:<id> if empty"
        },
        "event_id": {
          "type": "string",
          "description": "Real-world event key; sources sharing event_id are not independent (0.1.11+)"
        },
        "outlet_domain": {
          "type": "string",
          "description": "Digital outlet host; when independence_group empty → domain:<host> (0.1.12+)"
        },
        "wire_id": {
          "type": "string",
          "description": "News wire / syndication family; when independence_group empty → wire:<id> (0.1.12+)"
        },
        "metadata": { "type": "object" }
      }
    },
    "observation": {
      "type": "object",
      "required": ["source_ref", "observation_type", "subject"],
      "additionalProperties": true,
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "observation_type": { "$ref": "#/$defs/observationType" },
        "subject": { "type": "string", "minLength": 1 },
        "object": {
          "type": ["string", "null"]
        },
        "observed_at": {
          "type": ["string", "null"]
        },
        "event_id": {
          "type": "string",
          "description": "Real-world event key; inherits from source when empty"
        },
        "text_excerpt": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "numeric_value": {
          "type": ["number", "null"]
        },
        "unit": {
          "type": ["string", "null"]
        },
        "metadata": { "type": "object" }
      }
    }
  }
}
