{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/import-package.schema.json",
  "title": "AURORA import package",
  "description": "Package accepted by import_package(). See docs/import-schema.md.",
  "type": "object",
  "required": ["entities", "sources", "observations"],
  "additionalProperties": true,
  "properties": {
    "license": {
      "type": "string",
      "description": "Package-level default redistribution license applied to sources missing license (0.1.14+)"
    },
    "stage_unresolved": {
      "type": "boolean",
      "description": "Opt-in: stage provisional entities for unresolved subject/object names (0.1.39+). Alias: stage_unresolved_subjects."
    },
    "stage_unresolved_subjects": {
      "type": "boolean",
      "description": "Alias of stage_unresolved (0.1.39+)"
    },
    "provisional_entity_type": {
      "type": "string",
      "description": "Default entity_type for staged unresolved mentions (default PROVISIONAL; not industry-clusterable)"
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/observation" }
    },
    "documents": {
      "type": "array",
      "description": "Optional full-document records linked by observation.document_id (0.1.15+)",
      "items": { "$ref": "#/$defs/document" }
    }
  },
  "$defs": {
    "entityType": {
      "type": "string",
      "enum": [
        "COMPANY", "RESEARCH_INSTITUTE", "UNIVERSITY", "GOVERNMENT", "STANDARD_BODY",
        "PRODUCT", "TECHNOLOGY", "MATERIAL", "COMPONENT", "PROCESS", "FACILITY",
        "APPLICATION", "MARKET", "PERSON", "PROVISIONAL"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "COMPANY_FILING", "PATENT", "PAPER", "JOB_POSTING",
        "NEWS", "GOVERNMENT_PROGRAM", "STANDARD", "RESEARCH_NOTE"
      ]
    },
    "observationType": {
      "type": "string",
      "enum": [
        "PATENT_ACTIVITY", "HIRING_ACTIVITY", "CAPEX_ACTIVITY", "CAPACITY_EXPANSION",
        "PRODUCT_LAUNCH", "TECHNICAL_DEPENDENCY", "SUPPLIER_RELATIONSHIP",
        "CUSTOMER_RELATIONSHIP", "STRATEGIC_INVESTMENT", "STANDARD_ACTIVITY",
        "RESEARCH_ACTIVITY", "PRICE_PRESSURE", "LEAD_TIME_PRESSURE",
        "REGULATORY_SUPPORT", "ADOPTION_SIGNAL", "DEMAND_SIGNAL",
        "CANCELLATION_SIGNAL", "SHUTDOWN_SIGNAL"
      ]
    },
    "reliabilityTier": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "entity": {
      "type": "object",
      "required": ["entity_type", "canonical_name"],
      "additionalProperties": true,
      "properties": {
        "entity_type": { "$ref": "#/$defs/entityType" },
        "canonical_name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" },
        "country": { "type": "string" },
        "external_ids": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["system", "id"],
            "properties": {
              "system": { "type": "string" },
              "id": { "type": "string" }
            }
          }
        },
        "metadata": { "type": "object" }
      }
    },
    "source": {
      "type": "object",
      "required": ["source_type", "publisher", "title"],
      "additionalProperties": true,
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "source_type": { "$ref": "#/$defs/sourceType" },
        "publisher": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "published_at": {
          "type": ["string", "null"],
          "description": "Publication/grant ISO date; first 10 chars used as date"
        },
        "event_date": {
          "type": ["string", "null"],
          "description": "Activity/application/filing date (dual-date with published_at); first 10 chars used"
        },
        "excerpt": { "type": "string" },
        "independence_group": { "type": "string" },
        "reliability_tier": { "$ref": "#/$defs/reliabilityTier" },
        "url_or_local_path": { "type": "string" },
        "language": { "type": "string" },
        "family_id": {
          "type": "string",
          "description": "Patent/document family id; when set, independence_group defaults to family:<id> if empty"
        },
        "event_id": {
          "type": "string",
          "description": "Real-world event key; sources sharing event_id are not independent (0.1.11+)"
        },
        "outlet_domain": {
          "type": "string",
          "description": "Digital outlet host; when independence_group empty → domain:<host> (0.1.12+)"
        },
        "wire_id": {
          "type": "string",
          "description": "News wire / syndication family; when independence_group empty → wire:<id> (0.1.12+)"
        },
        "geo": {
          "type": "object",
          "description": "Location/jurisdiction (country, region, city, raw, jurisdiction); engine 0.1.13+",
          "additionalProperties": true
        },
        "country": {
          "type": "string",
          "description": "Shorthand for geo.country"
        },
        "jurisdiction": {
          "type": "string",
          "description": "Shorthand for geo.jurisdiction"
        },
        "license": {
          "type": "string",
          "description": "Redistribution license (SPDX-ish); required for public corpora (0.1.14+)"
        },
        "metadata": { "type": "object" }
      }
    },
    "observation": {
      "type": "object",
      "required": ["source_ref", "observation_type"],
      "additionalProperties": true,
      "description": "Requires subject and/or subject_raw (engine enforces at least one; 0.1.38+)",
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "observation_type": { "$ref": "#/$defs/observationType" },
        "subject": {
          "description": "Entity name, ext ref, or structured {name, external_ids}; optional if subject_raw set (0.1.38+)",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "object": {
          "type": ["string", "object", "null"]
        },
        "subject_raw": {
          "type": "string",
          "description": "Surface-form mention as written in source; staging / provenance (0.1.38+). May stand in for subject when subject is omitted."
        },
        "object_raw": {
          "type": "string",
          "description": "Surface-form object mention; staging / provenance (0.1.38+)"
        },
        "stage_unresolved": {
          "type": "boolean",
          "description": "Row-level opt-in to create provisional entities when subject/object does not resolve (0.1.39+)"
        },
        "subject_entity_type": {
          "type": "string",
          "description": "entity_type for staged subject provisional (default package provisional_entity_type / PROVISIONAL)"
        },
        "object_entity_type": {
          "type": "string",
          "description": "entity_type for staged object provisional"
        },
        "observed_at": {
          "type": ["string", "null"]
        },
        "event_id": {
          "type": "string",
          "description": "Real-world event key; inherits from source when empty"
        },
        "geo": {
          "type": "object",
          "description": "Location/jurisdiction; inherits from source when empty (0.1.13+)",
          "additionalProperties": true
        },
        "country": { "type": "string" },
        "jurisdiction": { "type": "string" },
        "document_id": {
          "type": "string",
          "description": "Link to documents[] or source-as-document id (0.1.15+)"
        },
        "char_span": {
          "description": "Character offsets [start, end] into document text",
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 2,
              "maxItems": 2
            },
            {
              "type": "object",
              "properties": {
                "start": { "type": "integer" },
                "end": { "type": "integer" }
              }
            }
          ]
        },
        "text_excerpt": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "numeric_value": {
          "type": ["number", "null"]
        },
        "unit": {
          "type": ["string", "null"]
        },
        "metadata": { "type": "object" }
      }
    },
    "document": {
      "type": "object",
      "required": ["document_id"],
      "additionalProperties": true,
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "body": { "type": "string" },
        "url_or_local_path": { "type": "string" },
        "url": { "type": "string" },
        "language": { "type": "string" },
        "license": { "type": "string" },
        "metadata": { "type": "object" }
      }
    }
  }
}
